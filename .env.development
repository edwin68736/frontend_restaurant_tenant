# Desarrollo: npm run dev | npm run tauri:dev
# Vite proxifica /api → backend (local o VPS). No hace falta CORS en el navegador.
#
# Backend local (misma convención que frontend_tenant/.env.development):
VITE_API_URL=http://localhost:3000
VITE_CENTRAL_API_URL=http://localhost:3000
VITE_APP_DOMAIN=localhost
#
# Backend en VPS (comenta lo de arriba y descomenta):
# VITE_API_URL=https://api.tukifac.com
# VITE_CENTRAL_API_URL=https://api.tukifac.com
# VITE_APP_DOMAIN=tukifac.com
