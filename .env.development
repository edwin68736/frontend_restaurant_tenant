# Desarrollo: npm run dev | npm run tauri:dev
# Vite proxifica /api → backend según X-Tenant-Api-Origin (sin CORS).
#
# Backend local — requiere en backend_principal/.env:
#   APP_DOMAIN=localhost
#   API_PUBLIC_URL=http://localhost:3000
#   APP_ENV=development
VITE_CENTRAL_API_URL=http://localhost:3000
#
# Backend en VPS (comenta localhost y descomenta):
# VITE_CENTRAL_API_URL=https://api.tukifac.com
