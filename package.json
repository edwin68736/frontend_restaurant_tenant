    "@capacitor/screen-orientation": "^7.0.2",
    "@capacitor/status-bar": "^7.0.2",
    "@tauri-apps/api": "^2.0.0",
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "hucre": "^0.5.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.8",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
