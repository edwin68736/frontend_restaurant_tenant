# =============================================================================
# Tukichef — App restaurante Tauri/Capacitor (copiar según entorno)
#   .env.development  → tauri dev / npm run dev
#   .env.production   → tauri build / npm run build
#   .env.capacitor    → npm run build:android
# =============================================================================

# ── DESARROLLO LOCAL ───────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_CENTRAL_API_URL=http://localhost:3000
VITE_APP_DOMAIN=localhost

# ── PRODUCCIÓN (tukifac.com) — copiar a .env.production ─────────────
#
# Paso 1 — bootstrap RUC (solo consulta pública):
# VITE_CENTRAL_API_URL=https://api.tukifac.com
#
# Paso 2 — tras RUC la app guarda api_url del tenant (ej. https://demo.tukifac.com)
# y usa ese host para login y API autenticada. Dominio raíz para construir URLs:
# VITE_APP_DOMAIN=tukifac.com
#
# Fallback legacy (solo bootstrap si no hay VITE_CENTRAL_API_URL):
# VITE_API_URL=https://api.tukifac.com
#
# NO operar el tenant solo contra api.tukifac.com en rutas autenticadas.
# Flujo correcto: api.tukifac.com → tenant-by-ruc → https://{slug}.tukifac.com/api/*
