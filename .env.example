# =============================================================================
# Tukichef — variables de entorno (Vite)
# Copia este archivo según el entorno:
#   .env.development  → tauri dev / npm run dev
#   .env.production   → tauri build / npm run build
#   .env.capacitor    → npm run build:android
# =============================================================================

# URL del backend Go central (SIN /api al final).
# El tenant NO va aquí: se elige por RUC en la app y se envía en X-Tenant-Slug.
VITE_API_URL=http://localhost:3000

# Producción (descomenta y usa en .env.production):
# VITE_API_URL=https://api.tukifac.com
