# =============================================================================
# Tukichef — App restaurante Tauri/Capacitor (copiar según entorno)
#   .env.development  → tauri dev / npm run dev
#   .env.production   → tauri build / npm run build
#   .env.capacitor    → npm run build:android
# =============================================================================

# ── DESARROLLO LOCAL ───────────────────────────────────────────────
# Vite proxifica /api → VITE_API_URL (local o VPS). Igual que frontend_tenant pero vía proxy.
VITE_API_URL=http://localhost:3000
VITE_CENTRAL_API_URL=http://localhost:3000
VITE_APP_DOMAIN=localhost

# ── PRODUCCIÓN (tukifac.com) — copiar a .env.production ─────────────
#
# API central: únicamente GET /api/public/tenant-by-ruc (primera vez, RUC).
# VITE_CENTRAL_API_URL=https://api.tukifac.com
#
# Tras el RUC la app persiste slug + api_url por instalación:
#   - Android: Capacitor Preferences
#   - Windows: %AppData%/…/tenant-binding.json (Tauri)
# No usar VITE_API_URL para el API del tenant (evita 403 missing_resolved_tenant).

# ── DIAGNÓSTICO SAFE AREA (temporal) ────────────────────────────────
# Panel flotante con env(safe-area-inset-*) y viewport en tiempo real.
# También activo en npm run dev (import.meta.env.DEV).
# VITE_DEBUG_SAFE_AREA=true
